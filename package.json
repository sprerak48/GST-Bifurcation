{
  "name": "gst-bifurcation-app",
  "version": "1.0.0",
  "description": "Automated GST Bifurcation for Multi-State Amazon Orders",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "csv-parse": "^5.5.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
